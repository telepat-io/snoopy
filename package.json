{
  "name": "@telepat/snoopy",
  "version": "0.1.11",
  "description": "Snoopy CLI for Reddit conversation monitoring jobs.",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "snoopy": "dist/src/cli/index.js"
  },
  "files": [
    "dist/src",
    "!dist/src/**/*.map",
    "!dist/src/scripts/**",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "docs:start": "npm --prefix website run start",
    "docs:build": "npm --prefix website run build",
    "docs:serve": "npm --prefix website run serve",
    "docs:deploy": "npm --prefix website run deploy",
    "e2e:smoke": "tsx src/scripts/e2eSmoke.ts",
    "lint": "eslint src tests --ext .ts,.tsx",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run build && npm test"
  },
  "keywords": [
    "reddit",
    "monitoring",
    "cli",
    "scheduler",
    "ai"
  ],
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/telepat-io/snoopy.git"
  },
  "bugs": {
    "url": "https://github.com/telepat-io/snoopy/issues"
  },
  "homepage": "https://docs.telepat.io/snoopy/",
  "license": "ISC",
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "keytar": "^7.9.0",
    "node-cron": "^4.2.1",
    "node-notifier": "^10.0.1",
    "openai": "^6.32.0",
    "react": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.0",
    "@types/node-notifier": "^8.0.5",
    "@types/react": "^19.2.14",
    "eslint": "^9.39.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
